{
  "ConnectionStrings": {
    "Default": "Data Source=crypto-decision-assistant.db"
  },
  "Binance": {
    "RestBaseUrl": "https://api.binance.com/"
  },
  "News": {
    "Providers": [
      {
        "Name": "Federal Reserve",
        "Url": "https://www.federalreserve.gov/feeds/press_all.xml",
        "Enabled": true,
        "Priority": 1
      },
      {
        "Name": "SEC Press Releases",
        "Url": "https://www.sec.gov/news/pressreleases.rss",
        "Enabled": true,
        "Priority": 2
      },
      {
        "Name": "CoinDesk",
        "Url": "https://www.coindesk.com/arc/outboundfeeds/rss/",
        "Enabled": true,
        "Priority": 3
      },
      {
        "Name": "The Block",
        "Url": "https://www.theblock.co/rss.xml",
        "Enabled": true,
        "Priority": 4
      },
      {
        "Name": "TradingView",
        "Url": "https://www.tradingview.com/feed/",
        "Enabled": true,
        "Priority": 5
      },
      {
        "Name": "Ethereum Foundation",
        "Url": "https://blog.ethereum.org/feed.xml",
        "Enabled": true,
        "Priority": 6
      },
      {
        "Name": "Glassnode Insights",
        "Url": "https://insights.glassnode.com/rss/",
        "Enabled": true,
        "Priority": 7
      },
      {
        "Name": "Reuters Crypto (no stable public RSS URL)",
        "Url": "",
        "Enabled": false,
        "Priority": 10
      },
      {
        "Name": "Binance Announcements (configure official feed when available)",
        "Url": "",
        "Enabled": false,
        "Priority": 11
      },
      {
        "Name": "CoinGecko or CoinMarketCap (configure licensed feed)",
        "Url": "",
        "Enabled": false,
        "Priority": 12
      }
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
